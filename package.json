{
  "name": "@narval-xyz/connect",
  "version": "0.0.6-rc.0",
  "description": "Narval Connect SDK & Wagmi connector",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/narval-xyz/connect-sdk.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "homepage": "https://narval.xyz",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "keywords": [
    "narval",
    "wagmi"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./wagmi": {
      "types": "./dist/wagmi/index.d.ts",
      "import": "./dist/wagmi/index.js",
      "default": "./dist/wagmi/index.js"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.ts"
      ],
      "wagmi": [
        "./dist/wagmi/index.d.ts"
      ]
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "@wagmi/core": ">=2.0.0",
    "react": ">=18.0.0",
    "viem": ">=2.16.2",
    "wagmi": ">=2.0.0"
  },
  "dependencies": {
    "ox": "^0.9.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/minimatch": "^5.1.2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.7.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0"
  }
}
